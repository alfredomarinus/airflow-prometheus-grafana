# Airflow
AIRFLOW_UID=50000
AIRFLOW_PROJ_DIR=./airflow

# Airflow admin user (created on first init)
_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=airflow
_AIRFLOW_WWW_USER_EMAIL=admin@example.com
_AIRFLOW_WWW_USER_FIRSTNAME=Admin
_AIRFLOW_WWW_USER_LASTNAME=User
_AIRFLOW_WWW_USER_ROLE=Admin

# Extra pip packages installed at container startup
_PIP_ADDITIONAL_REQUIREMENTS=

# Airflow secrets (override airflow.cfg via env vars)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW__CORE__FERNET_KEY=CHANGE_ME
# Generate with: python -c "import secrets,base64; print(base64.b64encode(secrets.token_bytes(16)).decode())"
AIRFLOW__CORE__INTERNAL_API_SECRET_KEY=CHANGE_ME
AIRFLOW__API__SECRET_KEY=CHANGE_ME
AIRFLOW__API_AUTH__JWT_SECRET=CHANGE_ME

# PostgreSQL
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow
POSTGRES_DB=airflow
POSTGRES_HOST=postgres

# Redis
REDIS_PASSWORD=redispass

# MinIO (S3-compatible object storage)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BROWSER_REDIRECT_URL=http://localhost:9001

# Airflow connection string for MinIO
AIRFLOW_CONN_MINIO_CONN=aws://minioadmin:minioadmin@?endpoint_url=http%3A%2F%2Fminio%3A9000

# Prometheus & StatsD Exporter
PROMETHEUS_PORT=9090
STATSD_EXPORTER_PORT=9102